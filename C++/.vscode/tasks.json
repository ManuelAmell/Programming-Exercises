{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar C++",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}",
                "-I/usr/include/qt6",
                "-I/usr/include/qt6/QtCore",
                "-I/usr/include/qt6/QtGui",
                "-I/usr/include/qt6/QtWidgets",
                "-lQt6Core",
                "-lQt6Gui",
                "-lQt6Widgets"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}
