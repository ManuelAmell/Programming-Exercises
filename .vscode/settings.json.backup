{
  // ============================================
  // ASOCIACIONES DE ARCHIVOS
  // ============================================
  // Define qué lenguaje usar para archivos específicos de C++
  "files.associations": {
    "iostream": "cpp",
    "iomanip": "cpp",
    "print": "cpp",
    "ostream": "cpp",
    "random": "cpp",
    "cstdio": "cpp"
  },
  // ============================================
  // TEMA Y APARIENCIA
  // ============================================
  // Tema preferido para modo oscuro
  "workbench.preferredDarkColorTheme": "One Dark Pro Night Flat",
  // Tema preferido para modo claro
  "workbench.preferredLightColorTheme": "One Dark Pro Night Flat",
  // Tema de iconos para archivos y carpetas
  "workbench.iconTheme": "material-icon-theme",
  // Tema de color activo
  "workbench.colorTheme": "One Dark Pro Night Flat",
  // ============================================
  // DOKI THEME - ZERO TWO (Darling in the Franxx)
  // ============================================
  // Habilita el fondo con el personaje
  "doki.background.enabled": true,
  // Habilita el sticker del personaje
  "doki.sticker.enabled": true,
  // Opacidad del fondo (0.0 = invisible, 1.0 = completamente visible)
  "doki.background.opacity": 0.1,
  // Opacidad del sticker (0.0 = invisible, 1.0 = completamente visible)
  "doki.sticker.opacity": 0.5,
  // Nombre del personaje del tema
  "doki.theme.name": "Zero Two",
  // Variante del tema (dark/light)
  "doki.theme.variant": "dark",
  // Nivel de visibilidad del sticker
  "doki.sticker.level": "on",
  // ============================================
  // CLANG-FORMAT (Formateo de C/C++)
  // ============================================
  // Ruta al ejecutable de clang-format
  "clang-format.executable": "/usr/bin/clang-format",
  // Estilo de formateo (Google, LLVM, Chromium, Mozilla, WebKit)
  "clang-format.style": "Google",
  // ============================================
  // FORMATEO GENERAL
  // ============================================
  // Formatea automáticamente al guardar
  "editor.formatOnSave": true,
  // Configuración específica para C++
  "[cpp]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  // Configuración específica para C
  "[c]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  // ============================================
  // CODE RUNNER (Ejecutar código rápidamente)
  // ============================================
  // Ejecuta el código en la terminal integrada
  "code-runner.runInTerminal": true,
  // Guarda el archivo antes de ejecutar
  "code-runner.saveFileBeforeRun": true,
  // Comando para compilar y ejecutar C++
  "code-runner.executorMap": {
    "cpp": "g++ \"$fullFileName\" -o \"$fileNameWithoutExt\" && ./\"$fileNameWithoutExt\""
  },
  // Limpia la salida anterior antes de ejecutar
  "code-runner.clearPreviousOutput": true,
  // ============================================
  // TERMINAL
  // ============================================
  // Terminal externa a usar (konsole para KDE)
  "terminal.external.linuxExec": "konsole",
  // Tipo de explorador de terminal
  "terminal.explorerKind": "external",
  // Tamaño de fuente en la terminal
  "terminal.integrated.fontSize": 13,
  // Fuente para la terminal
  "terminal.integrated.fontFamily": "'JetBrains Mono', 'Fira Code', monospace",
  // Scroll suave en terminal
  "terminal.integrated.smoothScrolling": true,
  // ============================================
  // C/C++ RUNNER (Compilación y ejecución)
  // ============================================
  // Ruta al compilador de C++
  "C_Cpp.default.compilerPath": "/usr/bin/g++",
  // No usar MSVC (compilador de Windows)
  "C_Cpp_Runner.useMsvc": false,
  // Compilador de C
  "C_Cpp_Runner.cCompilerPath": "gcc",
  // Compilador de C++
  "C_Cpp_Runner.cppCompilerPath": "g++",
  // Debugger a usar
  "C_Cpp_Runner.debuggerPath": "gdb",
  // Estándar de C (vacío = automático)
  "C_Cpp_Runner.cStandard": "",
  // Estándar de C++ (vacío = automático)
  "C_Cpp_Runner.cppStandard": "",
  // Habilita warnings al compilar
  "C_Cpp_Runner.enableWarnings": true,
  // Lista de warnings a mostrar
  "C_Cpp_Runner.warnings": [
    "-Wall", // Todos los warnings comunes
    "-Wextra", // Warnings extra
    "-Wpedantic", // Warnings de estándar estricto
    "-Wshadow", // Variables que ocultan otras
    "-Wformat=2", // Warnings de formato de printf/scanf
    "-Wcast-align", // Warnings de alineación de cast
    "-Wconversion", // Conversiones implícitas peligrosas
    "-Wsign-conversion", // Conversiones de signo
    "-Wnull-dereference" // Desreferencia de punteros null
  },
  // Warnings para MSVC (Windows)
  "C_Cpp_Runner.msvcWarnings": [
    "/W4",
    "/permissive-",
    "/w14242",
    "/w14287",
    "/w14296",
    "/w14311",
    "/w14826",
    "/w44062",
    "/w44242",
    "/w14905",
    "/w14906",
    "/w14263",
    "/w44265",
    "/w14928"
  ],
  // No tratar warnings como errores
  "C_Cpp_Runner.warningsAsError": false,
  // Argumentos adicionales del compilador
  "C_Cpp_Runner.compilerArgs": [],
  // Argumentos del linker
  "C_Cpp_Runner.linkerArgs": [],
  // Rutas de includes adicionales
  "C_Cpp_Runner.includePaths": [],
  // Patrones de búsqueda de includes
  "C_Cpp_Runner.includeSearch": [
    "*",
    "**/*"
  ],
  // Carpetas a excluir de la búsqueda
  "C_Cpp_Runner.excludeSearch": [
    "**/build",
    "**/build/**",
    "**/.*",
    "**/.*/**",
    "**/.vscode",
    "**/.vscode/**"
  ],
  // Sanitizers (herramientas de detección de errores)
  "C_Cpp_Runner.useAddressSanitizer": false, // Detecta errores de memoria
  "C_Cpp_Runner.useUndefinedSanitizer": false, // Detecta comportamiento indefinido
  "C_Cpp_Runner.useLeakSanitizer": false, // Detecta memory leaks
  // Mostrar tiempo de compilación
  "C_Cpp_Runner.showCompilationTime": false,
  // Optimización en tiempo de enlace
  "C_Cpp_Runner.useLinkTimeOptimization": false,
  // Warnings de seguridad de MSVC
  "C_Cpp_Runner.msvcSecureNoWarnings": false,
  "C_Cpp_Runner.msvcBatchPath": "",
  // ============================================
  // C/C++ INTELLISENSE
  // ============================================
  // Motor de IntelliSense (default = mejor opción)
  "C_Cpp.intelliSenseEngine": "default",
  // Autocompletado
  "C_Cpp.autocomplete": "default",
  // Subrayado de errores
  "C_Cpp.errorSquiggles": "enabled",
  // Estilo de formateo por defecto
  "C_Cpp.clang_format_fallbackStyle": "Google",
  // Ordenar includes automáticamente
  "C_Cpp.clang_format_sortIncludes": true,
  // Colorización mejorada de sintaxis
  "C_Cpp.enhancedColorization": "enabled",
  // ============================================
  // BETTER COMMENTS (Comentarios coloridos)
  // ============================================
  "better-comments.tags": [
    {
      "tag": "!", // ! Comentario importante (rojo)
      "color": "#FF2D00",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "?", // ? Pregunta o duda (azul)
      "color": "#3498DB",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "//", // // Código comentado (gris tachado)
      "color": "#474747",
      "strikethrough": true,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "todo", // todo Tarea pendiente (naranja)
      "color": "#FF8C00",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "*", // * Comentario destacado (verde)
      "color": "#98C379",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    }
  ],
  // ============================================
  // ERROR LENS (Errores inline)
  // ============================================
  // Habilita Error Lens
  "errorLens.enabled": true,
  // Niveles de diagnóstico a mostrar
  "errorLens.enabledDiagnosticLevels": [
    "error",
    "warning",
    "info"
  ],
  // Tamaño de fuente de los mensajes
  "errorLens.fontSize": "13",
  // Peso de la fuente
  "errorLens.fontWeight": "normal",
  // ============================================
  // INDENT RAINBOW (Guías de indentación coloridas)
  // ============================================
  // Colores para cada nivel de indentación
  "indentRainbow.colors": [
    "rgba(255,255,64,0.07)", // Amarillo
    "rgba(127,255,127,0.07)", // Verde
    "rgba(255,127,255,0.07)", // Magenta
    "rgba(79,236,236,0.07)" // Cyan
  ],
  // Color para indentación incorrecta
  "indentRainbow.errorColor": "rgba(255,64,64,0.3)",
  // Color para mezcla de tabs y espacios
  "indentRainbow.tabmixColor": "rgba(255,128,64,0.3)",
  // ============================================
  // DISCORD PRESENCE (Mostrar actividad en Discord)
  // ============================================
  "discord.enabled": true,
  // Texto cuando estás editando
  "discord.detailsEditing": "Editando {file_name}",
  // Texto cuando estás idle
  "discord.detailsIdle": "Idle",
  // Texto inferior cuando editas
  "discord.lowerDetailsEditing": "Workspace: {workspace}",
  // Texto inferior cuando estás idle
  "discord.lowerDetailsIdle": "Idle",
  // ============================================
  // LIVE SERVER (Servidor web para desarrollo)
  // ============================================
  // No mostrar mensajes informativos
  "liveServer.settings.donotShowInfoMsg": true,
  // No verificar tags HTML
  "liveServer.settings.donotVerifyTags": true,
  // ============================================
  // PRETTIER (Formateo de JS/TS)
  // ============================================
  "prettier.enable": true,
  // Usar comillas simples en lugar de dobles
  "prettier.singleQuote": true,
  // Ancho de tabulación
  "prettier.tabWidth": 2,
  // Usar espacios en lugar de tabs
  "prettier.useTabs": false,
  // ============================================
  // ESLINT (Linting para JavaScript/TypeScript)
  // ============================================
  "eslint.enable": true,
  // Lenguajes a validar
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  // ============================================
  // GITLENS (Información de Git inline)
  // ============================================
  // Mostrar información de Git en la línea actual
  "gitlens.currentLine.enabled": true,
  // Mostrar hover sobre la línea
  "gitlens.hovers.currentLine.over": "line",
  // Mostrar CodeLens (información sobre funciones)
  "gitlens.codeLens.enabled": true,
  // ============================================
  // GITHUB COPILOT (Asistente de IA)
  // ============================================
  // Habilitar Copilot para todos los lenguajes
  "github.copilot.enable": {
    "*": true,
    "yaml": true,
    "plaintext": true,
    "markdown": true,
    "cpp": true,
    "c": true
  },
  // ============================================
  // PYTHON
  // ============================================
  // Ruta al intérprete de Python (entorno virtual)
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  // Activar entorno virtual en terminal
  "python.terminal.activateEnvironment": true,
  // Habilitar linting
  "python.linting.enabled": true,
  // Usar Pylint como linter
  "python.linting.pylintEnabled": true,
  // Formateador a usar
  "python.formatting.provider": "autopep8",
  // Nivel de type checking
  "python.analysis.typeCheckingMode": "basic",
  // Autocompletado de imports
  "python.analysis.autoImportCompletions": true,
  // Configuración específica para Python
  "[python]": {
    "editor.defaultFormatter": "ms-python.python",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit" // Organizar imports al guardar
    }
  },
  // ============================================
  // JAVA
  // ============================================
  // Actualizar configuración de build automáticamente
  "java.configuration.updateBuildConfiguration": "automatic",
  // Análisis de null automático
  "java.compile.nullAnalysis.mode": "automatic",
  // Organizar imports al guardar
  "java.saveActions.organizeImports": true,
  // Compilación automática
  "java.autobuild.enabled": true,
  // Habilitar autocompletado
  "java.completion.enabled": true,
  // Adivinar argumentos de métodos
  "java.completion.guessMethodArguments": true,
  // Orden de imports
  "java.completion.importOrder": [
    "java",
    "javax",
    "com",
    "org"
  ],
  // Configuración específica para Java
  "[java]": {
    "editor.defaultFormatter": "redhat.java",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit" // Organizar imports al guardar
    }
  },
  // ============================================
  // ARCHIVOS Y GUARDADO
  // ============================================
  // Guardar automáticamente después de un delay
  "files.autoSave": "afterDelay",
  // Delay en milisegundos (1000ms = 1 segundo)
  "files.autoSaveDelay": 1000,
  // ============================================
  // EDITOR - SUGERENCIAS Y AUTOCOMPLETADO
  // ============================================
  // Habilitar sugerencias inline (como Copilot)
  "editor.inlineSuggest.enabled": true,
  // Seleccionar primera sugerencia automáticamente
  "editor.suggestSelection": "first",
  // Aceptar sugerencia con Enter
  "editor.acceptSuggestionOnEnter": "on",
  // Mostrar snippets primero
  "editor.snippetSuggestions": "top",
  // ============================================
  // EDITOR - FUENTES Y APARIENCIA
  // ============================================
  // Fuente del editor (con ligaduras)
  "editor.fontFamily": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', Consolas, 'Courier New', monospace",
  // Habilitar ligaduras (símbolos especiales como != -> >=)
  "editor.fontLigatures": true,
  // Tamaño de fuente
  "editor.fontSize": 14,
  // Altura de línea
  "editor.lineHeight": 22,
  // ============================================
  // EDITOR - BRACKETS Y GUÍAS
  // ============================================
  // Colorear pares de brackets
  "editor.bracketPairColorization.enabled": true,
  // Mostrar guías de brackets activos
  "editor.guides.bracketPairs": "active",
  // ============================================
  // EDITOR - MINIMAP
  // ============================================
  // Habilitar minimap (vista previa del código)
  "editor.minimap.enabled": true,
  // Mostrar slider del minimap al pasar el mouse
  "editor.minimap.showSlider": "mouseover",
  // ============================================
  // EDITOR - ANIMACIONES
  // ============================================
  // Parpadeo suave del cursor
  "editor.cursorBlinking": "smooth",
  // Animación suave del cursor al moverse
  "editor.cursorSmoothCaretAnimation": "on",
  // Scroll suave en el editor
  "editor.smoothScrolling": true,
  // Scroll suave en listas
  "workbench.list.smoothScrolling": true,
  // ============================================
  // DEBUG CONSOLE
  // ============================================
  // Tamaño de fuente en consola de debug
  "debug.console.fontSize": 13,
  // Fuente en consola de debug
  "debug.console.fontFamily": "'JetBrains Mono', monospace",
  // ============================================
  // WORKBENCH (Interfaz general)
  // ============================================
  // No mostrar página de inicio
  "workbench.startupEditor": "none",
  // No usar preview al abrir archivos (abre en nueva tab)
  "workbench.editor.enablePreview": false,
  // Limitar número de tabs abiertas
  "workbench.editor.limit.enabled": true,
  // Máximo de tabs abiertas (10)
  "workbench.editor.limit.value": 10,
  // ============================================
  // EXPLORER (Explorador de archivos)
  // ============================================
  // No confirmar al eliminar archivos
  "explorer.confirmDelete": false,
  // No confirmar al arrastrar y soltar
  "explorer.confirmDragAndDrop": false,
  // ============================================
  // GIT
  // ============================================
  // Hacer fetch automáticamente
  "git.autofetch": true,
  // No confirmar al hacer sync
  "git.confirmSync": false,
  // Commit inteligente (commit de todos los cambios)
  "git.enableSmartCommit": true,
  // ============================================
  // EXTENSIONES
  // ============================================
  // No ignorar recomendaciones de extensiones
  "extensions.ignoreRecommendations": false
}