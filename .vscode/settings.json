{
  "files.associations": {
    "iostream": "cpp",
    "iomanip": "cpp",
    "print": "cpp",
    "ostream": "cpp",
    "random": "cpp",
    "cstdio": "cpp"
  },
  "workbench.iconTheme": "material-icon-theme",
  "workbench.colorTheme": "44ed0d2d-cce8-4707-a0cf-5150e1b31c16",
  "doki.background.enabled": true,
  "doki.sticker.enabled": true,
  "doki.background.opacity": 0.1,
  "doki.sticker.opacity": 0.5,
  "doki.theme.name": "Zero Two",
  "doki.theme.variant": "dark",
  "doki.sticker.level": "on",
  "clang-format.executable": "/usr/bin/clang-format",
  "clang-format.style": "Google",
  "editor.formatOnSave": true,
  "[cpp]": {
    "editor.defaultFormatter": "ms-vscode.cpptools"
  },
  "[c]": {
    "editor.defaultFormatter": "ms-vscode.cpptools"
  },
  "code-runner.runInTerminal": true,
  "code-runner.saveFileBeforeRun": true,
  "code-runner.executorMap": {
    "cpp": "g++ \"$fullFileName\" -o \"$fileNameWithoutExt\" && ./\"$fileNameWithoutExt\""
  },
  "code-runner.clearPreviousOutput": true,
  "terminal.external.linuxExec": "kitty",
  "terminal.explorerKind": "external",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.fontFamily": "'JetBrains Mono', 'Fira Code', monospace",
  "terminal.integrated.smoothScrolling": true,
  "C_Cpp.default.compilerPath": "/usr/bin/g++",
  "C_Cpp_Runner.cCompilerPath": "gcc",
  "C_Cpp_Runner.cppCompilerPath": "g++",
  "C_Cpp_Runner.debuggerPath": "gdb",
  "C_Cpp_Runner.enableWarnings": true,
  "C_Cpp_Runner.warnings": [
    "-Wall",
    "-Wextra",
    "-Wpedantic"
  ],
  "C_Cpp.intelliSenseEngine": "default",
  "C_Cpp.errorSquiggles": "enabled",
  "C_Cpp.clang_format_fallbackStyle": "Google",
  "better-comments.tags": [
    {
      "tag": "!",
      "color": "#FF2D00"
    },
    {
      "tag": "?",
      "color": "#3498DB"
    },
    {
      "tag": "todo",
      "color": "#FF8C00"
    },
    {
      "tag": "*",
      "color": "#98C379"
    }
  ],
  "errorLens.enabled": true,
  "indentRainbow.colors": [
    "rgba(255,255,64,0.07)",
    "rgba(127,255,127,0.07)",
    "rgba(255,127,255,0.07)",
    "rgba(79,236,236,0.07)"
  ],
  "indentRainbow.errorColor": "rgba(255,64,64,0.3)",
  "indentRainbow.tabmixColor": "rgba(255,128,64,0.3)",
  "discord.enabled": true,
  "liveServer.settings.donotShowInfoMsg": true,
  "prettier.singleQuote": true,
  "prettier.tabWidth": 2,
  "gitlens.currentLine.enabled": true,
  "github.copilot.enable": {
    "*": false,
    "plaintext": true,
    "markdown": true,
    "scminput": false,
    "yaml": true,
    "cpp": true,
    "c": true,
    "python": false
  },
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.analysis.typeCheckingMode": "basic",
  "[python]": {
    "editor.defaultFormatter": "ms-python.python",
    "editor.formatOnSave": true
  },
  "java.configuration.updateBuildConfiguration": "automatic",
  "java.autobuild.enabled": true,
  "[java]": {
    "editor.formatOnSave": true
  },
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "editor.inlineSuggest.enabled": true,
  "editor.fontFamily": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', Consolas, 'Courier New', monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.lineHeight": 22,
  "editor.bracketPairColorization.enabled": true,
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "workbench.startupEditor": "none",
  "git.autofetch": true,
  "git.enableSmartCommit": true,
  "C_Cpp_Runner.msvcBatchPath": "",
  "C_Cpp_Runner.cStandard": "",
  "C_Cpp_Runner.cppStandard": "",
  "C_Cpp_Runner.useMsvc": false,
  "C_Cpp_Runner.msvcWarnings": [
    "/W4",
    "/permissive-",
    "/w14242",
    "/w14287",
    "/w14296",
    "/w14311",
    "/w14826",
    "/w44062",
    "/w44242",
    "/w14905",
    "/w14906",
    "/w14263",
    "/w44265",
    "/w14928"
  ],
  "C_Cpp_Runner.warningsAsError": false,
  "C_Cpp_Runner.compilerArgs": [],
  "C_Cpp_Runner.linkerArgs": [],
  "C_Cpp_Runner.includePaths": [],
  "C_Cpp_Runner.includeSearch": [
    "*",
    "**/*"
  ],
  "C_Cpp_Runner.excludeSearch": [
    "**/build",
    "**/build/**",
    "**/.*",
    "**/.*/**",
    "**/.vscode",
    "**/.vscode/**"
  ],
  "C_Cpp_Runner.useAddressSanitizer": false,
  "C_Cpp_Runner.useUndefinedSanitizer": false,
  "C_Cpp_Runner.useLeakSanitizer": false,
  "C_Cpp_Runner.showCompilationTime": false,
  "C_Cpp_Runner.useLinkTimeOptimization": false,
  "C_Cpp_Runner.msvcSecureNoWarnings": false
}